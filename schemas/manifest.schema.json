{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hs3testsuite.local/schemas/manifest.schema.json",
  "type": "object",
  "required": ["schema_version", "fixtures"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_by": { "type": "string" },
    "reference_backend": { "type": "string" },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "test_id",
          "path",
          "hashes",
          "features",
          "tags",
          "conformance",
          "checks"
        ],
        "additionalProperties": false,
        "properties": {
          "test_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
          "path": { "type": "string" },
          "hashes": {
            "type": "object",
            "required": ["sha256", "canonical_sha256"],
            "additionalProperties": false,
            "properties": {
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "canonical_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          },
          "features": {
            "type": "object",
            "required": ["sections", "types", "semantic"],
            "additionalProperties": false,
            "properties": {
              "sections": { "type": "array", "items": { "type": "string" } },
              "types": { "type": "array", "items": { "type": "string" } },
              "semantic": { "type": "array", "items": { "type": "string" } }
            }
          },
          "tags": { "type": "array", "items": { "type": "string" } },
          "conformance": { "type": "array", "items": { "type": "string" } },
          "checks": { "type": "array", "items": { "type": "string" } },
          "backend_expectations": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "xfail": { "type": "boolean" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
